# Database
DATABASE_URL=postgres://megav_user:megav_password@localhost:5432/megav_iptv?sslmode=disable

# Redis (for thumbnail queue)
REDIS_URL=redis://localhost:6379/0

# IPTV Playlist (M3U/M3U8 URL)
PLAYLIST_URL=http://your-provider.example.com/playlist.m3u8

# EPG (XMLTV URL, supports .gz)
EPG_URL=http://epg.example.com/epg.xml.gz

# Kinopoisk API (for movie posters)
# Get free key at https://kinopoiskapiunofficial.tech
KINOPOISK_API_KEY=

# Optional
DEBUG=false
FFMPEG_BIN=ffmpeg
